# Supabase configuration for waitlist functionality
# Get these values from your Supabase project dashboard: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Deployment notes:
# - Set these as environment variables in Vercel project settings
# - Also set ALLOWED_ORIGINS in Supabase edge function secrets to include your Vercel domain
#   e.g., ALLOWED_ORIGINS=https://your-domain.vercel.app,https://phono.app
